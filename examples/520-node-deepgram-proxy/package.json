{
  "name": "deepgram-node-proxy-server",
  "version": "1.0.0",
  "description": "A Node.js proxy server that keeps Deepgram API keys server-side while proxying REST and WebSocket requests",
  "main": "src/server.js",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "start": "node src/server.js",
    "test": "node tests/test.js"
  },
  "dependencies": {
    "@deepgram/sdk": "5.0.0",
    "dotenv": "16.6.1",
    "express": "4.21.2",
    "express-ws": "5.0.2",
    "ws": "8.20.0"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@<0.1.13": "0.1.13"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
