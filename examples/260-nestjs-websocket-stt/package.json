{
  "name": "deepgram-nestjs-websocket-stt",
  "version": "1.0.0",
  "description": "NestJS WebSocket gateway for real-time audio transcription using Deepgram streaming STT",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "tsc && node dist/main.js",
    "test": "node tests/test.js"
  },
  "dependencies": {
    "@deepgram/sdk": "5.0.0",
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/platform-socket.io": "11.1.17",
    "@nestjs/websockets": "11.1.17",
    "dotenv": "16.6.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "socket.io-client": "4.8.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
