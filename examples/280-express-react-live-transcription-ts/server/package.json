  "version": "1.0.0",
  "description": "Express.js backend that proxies WebSocket audio to Deepgram Live STT",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "5.0.0",
    "cors": "2.8.6",
