    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-ws": "3.0.6",
    "@types/node": "22.19.15",
    "@types/ws": "8.18.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
