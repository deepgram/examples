# Deepgram — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Jitsi Meet — room name on meet.jit.si (or your own Jitsi server)
JITSI_ROOM=my-test-room

# Optional: custom Jitsi domain (defaults to meet.jit.si)
# JITSI_DOMAIN=meet.jit.si

# Optional: JaaS (8x8.vc) App ID — set this if using Jitsi as a Service
# JAAS_APP_ID=
